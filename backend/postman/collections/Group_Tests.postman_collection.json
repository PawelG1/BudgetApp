{
  "info": {
    "name": "PASiR Group API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login Test Owner",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "if (pm.response.code === 200) {",
              "    pm.environment.set(\"jwt_token\", pm.response.text());",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"test@owner.com\",\n    \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/auth/login",
          "protocol": "http",
          "host": [ "localhost" ],
          "port": "8080",
          "path": [ "auth", "login" ]
        }
      }
    },
    {
      "name": "2. Create Group",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Group is created\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.createGroup).to.have.property(\"id\");",
              "    pm.expect(jsonData.data.createGroup.name).to.eql(\"Postman Test Group\");",
              "    pm.environment.set(\"created_group_id\", jsonData.data.createGroup.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation {\n  createGroup(groupDTO: {\n    name: \"Postman Test Group\"\n  }) {\n    id\n    name\n    ownerId\n  }\n}"
          }
        },
        "url": {
          "raw": "http://localhost:8080/graphql",
          "protocol": "http",
          "host": [ "localhost" ],
          "port": "8080",
          "path": [ "graphql" ]
        }
      }
    },
    {
      "name": "3. Get myGroups and verify membership",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Verify created group is in myGroups\", function () {",
              "    var jsonData = pm.response.json();",
              "    var groups = jsonData.data.myGroups;",
              "    var createdId = pm.environment.get(\"created_group_id\");",
              "    var found = groups.find(g => g.id == createdId);",
              "    pm.expect(found).to.not.be.undefined;",
              "    pm.expect(found.name).to.eql(\"Postman Test Group\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query {\n  myGroups {\n    id\n    name\n    ownerId\n  }\n}"
          }
        },
        "url": {
          "raw": "http://localhost:8080/graphql",
          "protocol": "http",
          "host": [ "localhost" ],
          "port": "8080",
          "path": [ "graphql" ]
        }
      }
    },
